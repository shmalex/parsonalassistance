# Copy to .env and fill in. .env is gitignored.

# ─── Telegram ───────────────────────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=put-your-bot-token-here
# Optional: restrict the bot to your own Telegram numeric id(s), comma-separated.
# Leave empty to allow anyone. Get your id from @userinfobot.
ALLOWED_TELEGRAM_IDS=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=put-your-openai-key-here
# Strong model for the mentor conversation + tool calls (better reasoning).
OPENAI_CHAT_MODEL=gpt-4o
# Cheap model for background utility calls (extraction, summary, nudges).
OPENAI_UTIL_MODEL=gpt-4o-mini
# Model that transcribes Russian voice messages.
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ─── Database (Postgres) ─────────────────────────────────────────────────────
# Either set these five vars...
POSTGRES_USER=assistant
POSTGRES_PASSWORD=change-me
POSTGRES_DB=assistant
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# ...or override everything with a full async URL (takes priority if set):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ─── Behaviour (all optional — sensible defaults baked in) ───────────────────
# How often (minutes) the bot checks in: "Чем сейчас занимаешься?".
# You asked for 5; default is 30 so it isn't spammy. Change here or with /interval.
CHECKIN_INTERVAL_MIN=30
TIMEZONE=Europe/Moscow
# Active hours (local, 24h) — the bot won't ping you outside this window.
ACTIVE_FROM=09:00
ACTIVE_TO=22:00

# ─── Language (i18n) ─────────────────────────────────────────────────────────
# All texts & prompts live in locales/<LOCALE>.json. To add a language: copy
# locales/ru.json → locales/en.json, translate, set LOCALE=en. Missing keys
# fall back to ru. Or point LOCALE_FILE at an explicit path (overrides LOCALE).
LOCALE=ru
# LOCALE_FILE=locales/ru.json

# ─── Google Calendar (optional, read-only — disabled until set up) ───────────
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
